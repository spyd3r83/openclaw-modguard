{
  "id": "modguard",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "vaultPath": {
        "type": "string",
        "description": "Path to vault database file (default: :memory:)"
      },
      "masterKey": {
        "type": "string",
        "description": "Master encryption key for vault"
      },
      "agentSentry": {
        "type": "object",
        "properties": {
          "enabled":         { "type": "boolean" },
          "K":               { "type": "number" },
          "windowSize":      { "type": "number" },
          "gamma":           { "type": "number" },
          "diagnosticProbe": { "type": "string" },
          "dryRunTimeoutMs": { "type": "number" }
        }
      }
    }
  }
}
